# Copy to .env.local for local overrides (never commit .env.local).
#
# CDN base URL for background music MP3 files.
# In production this is hardcoded in deploy-azure.yml — no secret needed.
# Override locally only if you want to test against the live CDN.
#
# Production value (set automatically by CI):
#   VITE_AUDIO_BASE_URL=https://cdn.cat-herding.net/audio
#
# Leave blank to fall back to local dev server (public/concepts/audio/).
VITE_AUDIO_BASE_URL=
