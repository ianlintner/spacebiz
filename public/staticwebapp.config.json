{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/portraits/*", "/concepts/*", "/wiki/*", "/qa/*"]
  },
  "mimeTypes": {
    ".webp": "image/webp",
    ".mp3":  "audio/mpeg",
    ".wasm": "application/wasm"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/portraits/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/concepts/hero/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/concepts/audio/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ],
  "platform": {
    "apiRuntime": "node:18"
  }
}
